    "type": "git",
    "url": "git+https://github.com/longsien/fastdotcom.git"
  },
  "bugs": {
    "url": "https://github.com/longsien/fastdotcom/issues"
  },
  "homepage": "https://github.com/longsien/fastdotcom#readme"
}
